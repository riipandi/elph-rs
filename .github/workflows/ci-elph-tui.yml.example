# yaml-language-server: $schema=https://json.schemastore.org/github-workflow.json

name: CI elph-tui

on:
  push:
    branches: ["**"]
    tags-ignore: ["*"]
    paths:
      - "crates/elph-tui/**"
      - "vendor/iocraft/**"
      - "Cargo.toml"
      - "Cargo.lock"
      - "rust-toolchain.toml"
      - "Makefile"
      - ".github/**"
  pull_request:
    paths:
      - "crates/elph-tui/**"
      - "vendor/iocraft/**"
      - "Cargo.toml"
      - "Cargo.lock"
      - "rust-toolchain.toml"
      - "Makefile"
      - ".github/**"

permissions:
  contents: read

concurrency:
  group: ci-elph-tui-${{ github.workflow }}-${{ github.head_ref || github.run_id }}
  cancel-in-progress: true

env:
  CI: true
  BINSTALL_DISABLE_TELEMETRY: true

jobs:
  quality:
    name: elph-tui (${{ matrix.os }})
    strategy:
      fail-fast: false
      matrix:
        os: [ubuntu-24.04, macos-14]
    runs-on: ${{ matrix.os }}
    timeout-minutes: 30
    steps:
      - uses: actions/checkout@v7

      - name: Setup Rust
        uses: ./.github/setup-rust
        with:
          sharedKey: ci-elph-tui-${{ matrix.os }}
          saveCache: ${{ github.ref == 'refs/heads/main' }}

      - name: Check formatting
        run: cargo fmt --all --check

      - name: Check compilation
        run: make check-elph-tui

      - name: Lint
        run: make lint-elph-tui

      - name: Test
        run: make test-elph-tui

      - name: Build examples
        run: make build-elph-tui-examples

      - name: Show sccache statistics
        if: always()
        uses: ./.github/show-sccache-stats
