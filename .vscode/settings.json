{
    "editor.defaultFormatter": "oxc.oxc-vscode",
    "editor.codeActionsOnSave": {
        "source.fixAll.oxc": "always"
    },
    "files.associations": {
        "*.vars": "dotenv",
        "*.yaml.example": "yaml",
        "*.yml.example": "yaml",
        "wrangler.json": "jsonc"
    },
    "files.readonlyInclude": {
        "**/*.lock": true
    },
    "files.watcherExclude": {
        "**/*.lock": true
    },
    "search.exclude": {
        "**/*.lock": true
    },
    "protobuf.externalLinter.enabled": true,
    "protobuf.externalLinter.linter": "buf",
    "protobuf.externalLinter.bufPath": "buf",
    "[javascript]": {
        "editor.codeActionsOnSave": {
            "source.fixAll": "explicit"
        },
        "editor.defaultFormatter": "oxc.oxc-vscode",
        "editor.formatOnPaste": true,
        "editor.formatOnSave": true
    },
    "[json]": {
        "editor.defaultFormatter": "oxc.oxc-vscode"
    },
    "[jsonc]": {
        "editor.defaultFormatter": "oxc.oxc-vscode"
    },
    "[jsonl]": {
        "editor.defaultFormatter": "oxc.oxc-vscode"
    },
    "[markdown]": {
        "editor.defaultFormatter": "darkriszty.markdown-table-prettify"
    },
    "[toml]": {
        "editor.defaultFormatter": "Shellomo.enhanced-toml",
        "editor.formatOnSave": false
    },
    "[typescript]": {
        "editor.codeActionsOnSave": {
            "source.fixAll": "explicit"
        },
        "editor.defaultFormatter": "oxc.oxc-vscode",
        "editor.formatOnPaste": true,
        "editor.formatOnSave": true
    }
}
