{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://github.com/riipandi/elph/schemas/mcp-schema.json",
    "title": "Elph MCP configuration",
    "description": "MCP server definitions for Elph, typically stored at ~/.elph/mcp.json. Supports stdio, streamable HTTP, and legacy SSE transports; global/per-server tool policy; and OAuth for remote servers. Matches elph_agent::mcp::McpConfig.",
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "servers": {
            "type": "object",
            "description": "Named MCP server definitions. Keys are stable server ids used for tool namespacing and CLI management.",
            "default": {},
            "propertyNames": {
                "type": "string",
                "minLength": 1
            },
            "additionalProperties": {
                "$ref": "#/definitions/mcpServer"
            }
        },
        "policy": {
            "$ref": "#/definitions/policy",
            "description": "Global tool policy. Merged with each server's policy (server rules take precedence)."
        }
    },
    "definitions": {
        "timeoutMs": {
            "type": "integer",
            "minimum": 1,
            "description": "Per-operation timeout in milliseconds for list-tools and call-tool. Defaults to 60000 when omitted."
        },
        "disabled": {
            "type": "boolean",
            "default": false,
            "description": "When true, the server is skipped during discovery and tool calls."
        },
        "policyAction": {
            "type": "string",
            "enum": ["allow", "requireApproval", "deny"],
            "description": "allow = run without approval; requireApproval = expose but prompt user; deny = hide from model."
        },
        "policy": {
            "type": "object",
            "additionalProperties": false,
            "description": "Tool allow/deny/approval policy. Patterns support exact names, prefix* and *suffix globs.",
            "properties": {
                "default": {
                    "$ref": "#/definitions/policyAction",
                    "default": "requireApproval"
                },
                "allow": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 },
                    "default": [],
                    "description": "Exposed without approval (e.g. mcp_fs__read*)."
                },
                "deny": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 },
                    "default": [],
                    "description": "Never exposed to the model."
                },
                "requireApproval": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 },
                    "default": [],
                    "description": "Exposed but require user approval."
                }
            }
        },
        "mcpServer": {
            "description": "One MCP server endpoint. Discriminated by the `type` field.",
            "oneOf": [
                { "$ref": "#/definitions/stdioServer" },
                { "$ref": "#/definitions/httpServer" },
                { "$ref": "#/definitions/sseServer" }
            ]
        },
        "stdioServer": {
            "type": "object",
            "description": "Local process speaking MCP over stdio.",
            "additionalProperties": false,
            "required": ["type", "command"],
            "properties": {
                "type": {
                    "type": "string",
                    "const": "stdio"
                },
                "command": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Executable to spawn (absolute path or PATH lookup)."
                },
                "args": {
                    "type": "array",
                    "default": [],
                    "items": { "type": "string" }
                },
                "env": {
                    "type": "object",
                    "default": {},
                    "additionalProperties": { "type": "string" }
                },
                "cwd": {
                    "type": "string",
                    "minLength": 1
                },
                "timeoutMs": { "$ref": "#/definitions/timeoutMs" },
                "disabled": { "$ref": "#/definitions/disabled" },
                "policy": { "$ref": "#/definitions/policy" }
            }
        },
        "httpServer": {
            "type": "object",
            "additionalProperties": false,
            "description": "Remote MCP over streamable HTTP.",
            "required": ["type", "url"],
            "properties": {
                "type": {
                    "type": "string",
                    "enum": ["http", "streamableHttp", "streamable-http"]
                },
                "url": {
                    "type": "string",
                    "minLength": 1,
                    "format": "uri",
                    "description": "Base URL of the MCP endpoint (e.g. https://host/mcp)."
                },
                "headers": {
                    "type": "object",
                    "default": {},
                    "additionalProperties": { "type": "string" }
                },
                "authToken": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Bearer token without `Bearer ` prefix. Prefer authTokenEnv or OAuth."
                },
                "authTokenEnv": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Environment variable holding a bearer token."
                },
                "timeoutMs": { "$ref": "#/definitions/timeoutMs" },
                "disabled": { "$ref": "#/definitions/disabled" },
                "oauth": {
                    "type": "boolean",
                    "default": false,
                    "description": "Prefer OAuth credentials from `elph mcp auth <name>`."
                },
                "oauthScopes": {
                    "type": "array",
                    "items": { "type": "string" },
                    "default": [],
                    "description": "Scopes requested during OAuth authorization."
                },
                "policy": { "$ref": "#/definitions/policy" }
            }
        },
        "sseServer": {
            "type": "object",
            "additionalProperties": false,
            "description": "Legacy MCP HTTP+SSE transport (pre–Streamable HTTP).",
            "required": ["type", "url"],
            "properties": {
                "type": {
                    "type": "string",
                    "const": "sse"
                },
                "url": {
                    "type": "string",
                    "minLength": 1,
                    "format": "uri",
                    "description": "SSE endpoint URL (e.g. http://localhost:3000/sse)."
                },
                "headers": {
                    "type": "object",
                    "default": {},
                    "additionalProperties": { "type": "string" }
                },
                "authToken": { "type": "string", "minLength": 1 },
                "authTokenEnv": { "type": "string", "minLength": 1 },
                "timeoutMs": { "$ref": "#/definitions/timeoutMs" },
                "disabled": { "$ref": "#/definitions/disabled" },
                "oauth": {
                    "type": "boolean",
                    "default": false
                },
                "oauthScopes": {
                    "type": "array",
                    "items": { "type": "string" },
                    "default": []
                },
                "policy": { "$ref": "#/definitions/policy" }
            }
        }
    },
    "examples": [
        {
            "policy": {
                "default": "requireApproval",
                "allow": ["mcp_fs__list*", "mcp_fs__read*"],
                "deny": ["mcp_dangerous__*"]
            },
            "servers": {
                "filesystem": {
                    "type": "stdio",
                    "command": "npx",
                    "args": ["-y", "@modelcontextprotocol/server-filesystem", "/tmp"]
                },
                "remote": {
                    "type": "http",
                    "url": "https://example.com/mcp",
                    "oauth": true,
                    "oauthScopes": ["read", "write"]
                },
                "legacy": {
                    "type": "sse",
                    "url": "http://localhost:3000/sse",
                    "authTokenEnv": "MCP_TOKEN"
                }
            }
        }
    ]
}
